generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  DONOR
  HOSPITAL_STAFF
}

enum BloodGroup {
  O_POS
  O_NEG
  A_POS
  A_NEG
  B_POS
  B_NEG
  AB_POS
  AB_NEG
}

enum RequestType {
  STANDARD
  EMERGENCY
}

enum RequestStatus {
  OPEN
  MATCHING
  FULFILLED
  CANCELLED
}

enum PriorityLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

model User {
  id               String          @id @default(cuid())
  email            String          @unique
  passwordHash     String
  role             Role
  emailVerified    Boolean         @default(false)
  isActive         Boolean         @default(true)
  failedLoginCount Int             @default(0)
  lockedUntil      DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  donorProfile     Donor?
  hospitalProfile  Hospital?
  refreshTokens    RefreshToken[]
  emailVerificationTokens EmailVerificationToken[]
  notifications    Notification[]
  auditLogs        AuditLog[]      @relation("AuditActor")

  @@index([createdAt])
}

model Donor {
  id                      String         @id @default(cuid())
  userId                   String         @unique
  fullName                 String
  bloodGroup               BloodGroup
  location                 String
  latitude                 Float?
  longitude                Float?
  eligibilityStatus        Boolean        @default(true)
  availabilityStatus       Boolean        @default(true)
  emergencyContactName     String
  emergencyContactPhone    String
  notificationEmailEnabled Boolean        @default(true)
  notificationSmsEnabled   Boolean        @default(false)
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt
  user                     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  donationHistory          Donation[]
  appointments             Appointment[]
  donorMatches             BloodRequest[] @relation("MatchedDonors")

  @@index([bloodGroup])
  @@index([location])
  @@index([createdAt])
}

model Hospital {
  id               String         @id @default(cuid())
  userId            String         @unique
  hospitalName      String
  registrationCode  String         @unique
  address           String
  location          String
  latitude          Float?
  longitude         Float?
  contactName       String
  contactPhone      String
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  bloodRequests     BloodRequest[]
  inventoryItems    InventoryItem[]
  appointments      Appointment[]

  @@index([location])
  @@index([createdAt])
}

model BloodRequest {
  id                     String        @id @default(cuid())
  hospitalId             String
  bloodGroup             BloodGroup
  unitsNeeded            Int
  type                   RequestType
  priority               PriorityLevel @default(MEDIUM)
  status                 RequestStatus @default(OPEN)
  location               String
  notes                  String?
  requiredBy             DateTime
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  hospital               Hospital      @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  matchedDonors          Donor[]       @relation("MatchedDonors")
  notificationDispatches Notification[]

  @@index([status])
  @@index([location])
  @@index([bloodGroup])
  @@index([createdAt])
}

model InventoryItem {
  id            String     @id @default(cuid())
  hospitalId    String
  bloodGroup    BloodGroup
  availableUnits Int
  lastUpdated   DateTime   @updatedAt
  createdAt     DateTime   @default(now())
  hospital      Hospital   @relation(fields: [hospitalId], references: [id], onDelete: Cascade)

  @@unique([hospitalId, bloodGroup])
  @@index([bloodGroup])
  @@index([createdAt])
}

model Appointment {
  id              String            @id @default(cuid())
  donorId          String
  hospitalId       String
  scheduledAt      DateTime
  status           AppointmentStatus @default(SCHEDULED)
  notes            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  donor            Donor             @relation(fields: [donorId], references: [id], onDelete: Cascade)
  hospital         Hospital          @relation(fields: [hospitalId], references: [id], onDelete: Cascade)

  @@index([scheduledAt])
  @@index([createdAt])
}

model Donation {
  id            String   @id @default(cuid())
  donorId        String
  donatedAt      DateTime
  unitsDonated   Int
  location       String
  notes          String?
  createdAt      DateTime @default(now())
  donor          Donor    @relation(fields: [donorId], references: [id], onDelete: Cascade)

  @@index([createdAt])
}

model Notification {
  id              String       @id @default(cuid())
  userId           String
  bloodRequestId   String?
  title            String
  body             String
  channel          String
  delivered        Boolean      @default(false)
  createdAt        DateTime     @default(now())
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  bloodRequest     BloodRequest? @relation(fields: [bloodRequestId], references: [id], onDelete: SetNull)

  @@index([createdAt])
}

model RefreshToken {
  id          String   @id @default(cuid())
  userId      String
  tokenHash   String
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([createdAt])
}

model PasswordResetToken {
  id          String   @id @default(cuid())
  userId      String
  tokenHash   String   @unique
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime @default(now())

  @@index([expiresAt])
  @@index([createdAt])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  createdAt   DateTime @default(now())
  actor       User?    @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([action])
}
